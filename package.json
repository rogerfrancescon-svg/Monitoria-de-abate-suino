    "clsx": "^2.1.1",
    "dexie": "^4.4.4",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.1",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-swipeable": "^7.0.2",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
